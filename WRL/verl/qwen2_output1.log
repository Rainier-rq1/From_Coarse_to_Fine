[36m(main_task pid=25448)[0m e = 2s - 2e
[36m(main_task pid=25448)[0m 
[36m(main_task pid=25448)[0m Bring terms with e to left:
[36m(main_task pid=25448)[0m e + 2e = 2s
[36m(main_task pid=25448)[0m 3e = 2s
[36m(main_task pid=25448)[0m e = (2/3)s
[36m(main_task pid=25448)[0m 
