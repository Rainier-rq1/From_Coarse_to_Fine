[36m(main_task pid=25448)[0m Cross-multiplying:
[36m(main_task pid=25448)[0m - (z - s) = e
[36m(main_task pid=25448)[0m - z - s = -e
[36m(main_task pid=25448)[0m - z = s - e
[36m(main_task pid=25448)[0m 
